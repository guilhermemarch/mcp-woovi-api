# Environment Variables Template
# Copy this to .env and fill in your sandbox/test values

# Required Woovi/OpenPix credential
WOOVI_APP_ID=your_sandbox_app_id_here

# Prefer sandbox while developing the challenge
WOOVI_API_URL=https://api.woovi-sandbox.com

# Optional: raw (Authorization: appId) or bearer (Authorization: Bearer token)
WOOVI_AUTH_MODE=raw

# Optional structured logging level
WOOVI_LOG_LEVEL=info

# HTTP transport port
PORT=3000

# Required for HTTP transport: bearer token protecting POST /mcp and GET /events
MCP_HTTP_AUTH_TOKEN=replace-with-strong-random-token

# Optional but recommended: if set, enables protected POST /webhooks/events
WOOVI_WEBHOOK_INGRESS_TOKEN=

# Optional server identity overrides
MCP_SERVER_NAME=woovi-mcp-server
MCP_SERVER_VERSION=1.0.0
