      "name": "Charges",
      "item": [
        {
          "name": "Create Charge",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{appId}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"value\": 5000,\n  \"correlationID\": \"{{chargeCorrelationId}}\",\n  \"comment\": \"Charge created from Postman\",\n  \"expiresDate\": \"2026-12-31T23:59:59.000Z\",\n  \"fixedLocation\": true,\n  \"customer\": {\n    \"name\": \"Example Customer\",\n    \"email\": \"{{customerEmail}}\",\n    \"phone\": \"11999999999\",\n    \"taxID\": \"12345678901\",\n    \"correlationID\": \"cust-correlation-123\",\n    \"address\": {\n      \"city\": \"Palmas\",\n      \"state\": \"TO\"\n    }\n  },\n  \"additionalInfo\": [\n    {\n      \"key\": \"orderId\",\n      \"value\": \"A-123\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/charge?return_existing=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "charge"
              ],
              "query": [
                {
                  "key": "return_existing",
                  "value": "true"
                }
              ]
            },
            "description": "Matches packages/client/src/client.ts:createCharge, including the expanded charge payload supported by the MCP tool and client."
          }
        },
        {
          "name": "Get Charge",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{appId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/charge/{{chargeCorrelationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "charge",
                "{{chargeCorrelationId}}"
              ]
            },
            "description": "Matches packages/client/src/client.ts:getCharge."
          }
        },
        {
          "name": "List Charges",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{appId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/charge?skip=0&limit=10&status=ACTIVE&start=2026-01-01T00:00:00.000Z&end=2026-01-31T23:59:59.999Z&customer={{customerId}}&subscription={{subscriptionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "charge"
              ],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "ACTIVE"
                },
                {
                  "key": "start",
                  "value": "2026-01-01T00:00:00.000Z"
                },
                {
                  "key": "end",
                  "value": "2026-01-31T23:59:59.999Z"
                },
                {
                  "key": "customer",
                  "value": "{{customerId}}"
                },
                {
                  "key": "subscription",
                  "value": "{{subscriptionId}}"
                }
              ]
            },
            "description": "Matches packages/client/src/client.ts:listCharges. Note the query names are start/end, not startDate/endDate, and subscription is forwarded when present."
          }
        }
      ]
    },
