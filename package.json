{
  "name": "woovi-mcp-server",
  "version": "0.1.0",
  "description": "Woovi MCP Server - Model Context Protocol integration for Woovi API",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r exec tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run packages/client/tests/unit packages/server/tests/unit",
    "test:client:unit": "vitest run packages/client/tests/unit",
    "test:server:unit": "vitest run packages/server/tests/unit",
    "test:integration": "vitest run packages/server/tests/integration",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "quality": "pnpm build && pnpm typecheck && pnpm test:coverage && node scripts/verify-challenge.mjs",
    "dev": "pnpm --filter @woovi/server dev",
    "start": "pnpm --filter @woovi/server start",
    "start:stdio": "pnpm --filter @woovi/server start:stdio",
    "start:http": "pnpm --filter @woovi/server start:http",
    "verify": "node scripts/verify-challenge.mjs",
    "verify:build": "pnpm build && node scripts/verify-challenge.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
